# Local environment files
.env
.env.*
!*.env.example

# Runtime data generated by stack templates
stacks/**/data/
stacks/**/postgres/
stacks/**/redis/
stacks/**/uploads/
stacks/**/secrets/

# Local secrets and credentials
HOMELAB_CREDENTIALS.md
credentials.md
secrets.md
/root/sovereign-secrets/
sovereign-secrets/
*credentials*
*secret*
*.secret
*.secrets
!docs/99_reference/LOCAL_CREDENTIALS_TEMPLATE.md

# Generated public-CA onboarding artifacts are rendered from the live CA.
stacks/trust-portal/site/downloads/*
!stacks/trust-portal/site/downloads/.gitkeep

# Local logs and temporary files
*.log
*.tmp
*.bak
__pycache__/
*.pyc
.agents/
**/.agents/

# OS/editor noise
.DS_Store
Thumbs.db
