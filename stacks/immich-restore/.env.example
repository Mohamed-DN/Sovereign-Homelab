# Emergency Immich restore stack (Windows Docker Desktop / WSL2).
# Copy to .env, set the values, and NEVER commit the real .env.
#
# IMMICH_VERSION and the DB identity must match the mirrored snapshot. The
# recovery-metadata.txt inside the restore records the exact image tags used
# when the snapshot was taken.

TZ=Europe/Rome

# Must match the version recorded in the snapshot recovery metadata.
IMMICH_VERSION=v3.0.1

# Host port for the emergency UI/API on the Windows PC.
IMMICH_PORT=2283

# Path to the RESTORED upload tree produced by Restore-ImmichLatest.ps1.
# Docker Desktop accepts Windows paths with forward slashes, for example:
#   C:/Sovereign-Restore/Immich/mnt/immich-library/upload
IMMICH_UPLOAD_LOCATION=C:/Sovereign-Restore/Immich/mnt/immich-library/upload

# Database identity. Use the same username/database name as production so the
# dump restores cleanly. Set a throwaway password for this isolated stack.
IMMICH_DB_PASSWORD=CHANGE_ME_TEMPORARY_LOCAL_PASSWORD
IMMICH_DB_USERNAME=postgres
IMMICH_DB_DATABASE_NAME=immich
