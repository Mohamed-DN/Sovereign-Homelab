TZ=Europe/Rome

# NetAlertX follows the upstream Docker Compose baseline, which currently uses
# the official rolling image channel. This exception is documented in
# docs/99_reference/PINNED_IMAGE_VERSIONS.md.
NETALERTX_IMAGE=ghcr.io/netalertx/netalertx:latest
NETALERTX_PORT=20211
NETALERTX_GRAPHQL_PORT=20212
NETALERTX_NETWORK_MODE=host
NETALERTX_LISTEN_ADDR=0.0.0.0

# ntfy is pinned because it publishes stable versioned tags.
NTFY_IMAGE=binwiederhier/ntfy:v2.24.0
NTFY_PORT=8093
NTFY_BASE_URL=http://alerts.internal

# Scrutiny omnibus follows the upstream rolling-image deployment model. This
# exception is documented in docs/99_reference/PINNED_IMAGE_VERSIONS.md.
SCRUTINY_IMAGE=ghcr.io/analogj/scrutiny:latest
SCRUTINY_PORT=8085
SCRUTINY_INFLUX_PORT=8086
