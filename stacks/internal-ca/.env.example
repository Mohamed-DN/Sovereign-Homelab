TZ=Europe/Rome

STEP_CA_TAG=0.30.2
STEP_CA_PORT=9002
STEP_CA_NAME=Sovereign Homelab Internal CA
STEP_CA_DNS_NAMES=ca.internal,localhost,127.0.0.1,LXC101_IP
