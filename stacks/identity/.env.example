# Copy to .env and replace every CHANGE_ME value.

# Pin to the release tested in docs/99_reference/PINNED_IMAGE_VERSIONS.md.
AUTHENTIK_TAG=2026.5.3
AUTHENTIK_HTTP_PORT=9000
AUTHENTIK_HTTPS_PORT=9443
AUTHENTIK_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_48
AUTHENTIK_ERROR_REPORTING__ENABLED=false

POSTGRES_DB=authentik
POSTGRES_USER=authentik
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_36

AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=CHANGE_ME_LONG_ADMIN_PASSWORD
AUTHENTIK_BOOTSTRAP_TOKEN=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_36

# LDAP outpost token (from Authentik: Outposts -> LDAP -> View token). Root-only.
LDAP_OUTPOST_TOKEN=CHANGE_ME_LDAP_OUTPOST_TOKEN
