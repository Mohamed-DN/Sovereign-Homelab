TZ=Europe/Rome

OBSIDIAN_COUCHDB_TAG=3.5.2
OBSIDIAN_COUCHDB_PORT=5984

# CouchDB server admin. Used by Fauxton (NPM injects it after the Authentik
# gate on fauxton.internal) and for administration. NOT for sync clients.
OBSIDIAN_COUCHDB_USER=CHANGE_ME
OBSIDIAN_COUCHDB_PASSWORD=CHANGE_ME_GENERATE_LONG_RANDOM
OBSIDIAN_COUCHDB_SECRET=CHANGE_ME_GENERATE_LONG_RANDOM

# Least-privilege account that the Obsidian LiveSync clients actually use.
# It is a member of OBSIDIAN_VAULT_DB and nothing else: it cannot create or
# drop databases, read _users, or change the server config. This credential
# lives on every synced phone/laptop, so it must not be the admin above.
OBSIDIAN_CLIENT_USER=obsidian_client
OBSIDIAN_CLIENT_PASSWORD=CHANGE_ME_GENERATE_LONG_RANDOM
OBSIDIAN_VAULT_DB=obsidiandb
