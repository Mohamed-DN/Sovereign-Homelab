TZ=Europe/Rome

PAPERLESS_TAG=2.20.15
PAPERLESS_PORT=8010
PAPERLESS_SECRET_KEY=CHANGE_ME_GENERATE_LONG_RANDOM
PAPERLESS_URL=https://paper.internal
PAPERLESS_DB=paperless
PAPERLESS_DB_USER=paperless
PAPERLESS_DB_PASSWORD=CHANGE_ME

# Database config
POSTGRES_USER=paperless
POSTGRES_DB=paperless

# OIDC (Authentik SSO) — client_id/secret from the "Paperless OIDC" provider in
# Authentik (Applications > Paperless-ngx > Provider). PAPERLESS_SOCIALACCOUNT_
# PROVIDERS must stay valid single-line JSON; keep this whole file root-only,
# it is already gitignored (only .env.example is committed).
PAPERLESS_APPS=allauth.socialaccount.providers.openid_connect
PAPERLESS_SOCIALACCOUNT_PROVIDERS={"openid_connect":{"OAUTH_PKCE_ENABLED":true,"APPS":[{"provider_id":"authentik","name":"Sovereign SSO","client_id":"CHANGE_ME","secret":"CHANGE_ME","settings":{"server_url":"https://auth.internal/application/o/paperless/.well-known/openid-configuration","fetch_userinfo":true,"email_authentication":true}}],"SCOPE":["openid","profile","email"]}}
PAPERLESS_SOCIAL_AUTO_SIGNUP=true
PAPERLESS_SOCIALACCOUNT_ALLOW_SIGNUPS=true
PAPERLESS_LOGOUT_REDIRECT_URL=https://auth.internal/application/o/paperless/end-session/
