# Copy this file outside the repository to:
# /root/sovereign-secrets/homepage-monitoring.env
#
# Keep the live file owned by root with mode 0600. Use dedicated read-only
# API tokens belonging to the sole_monitor service identities. Never use a
# human administrator password or commit real token values.

HOMEPAGE_VAR_PVE_TOKEN_ID=sole_monitor@pve!homepage
HOMEPAGE_VAR_PVE_TOKEN_SECRET=CHANGE_ME_PVE_READ_ONLY_TOKEN
HOMEPAGE_VAR_PBS_TOKEN_ID=sole_monitor@pbs!homepage
HOMEPAGE_VAR_PBS_TOKEN_SECRET=CHANGE_ME_PBS_READ_ONLY_TOKEN
