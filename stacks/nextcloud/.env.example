TZ=Europe/Rome

NEXTCLOUD_AIO_PORT=8086
NEXTCLOUD_AIO_IMAGE=ghcr.io/nextcloud-releases/all-in-one:latest
NEXTCLOUD_APACHE_PORT=11000
NEXTCLOUD_DATADIR=/opt/sovereign/data/nextcloud
NEXTCLOUD_SKIP_DOMAIN_VALIDATION=true

# Explicit exception: Nextcloud AIO upstream publishes the mastercontainer as
# ghcr.io/nextcloud-releases/all-in-one:latest. The mastercontainer manages its
# own child container channel. Do not replace this with nextcloud/all-in-one tags.

# This lab uses files.internal as a VPN-only/private DNS name.
# Keep domain validation disabled only for private .internal deployments.
